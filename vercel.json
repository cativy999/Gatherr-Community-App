{
  "rewrites": [
    {
      "source": "/event/:id",
      "missing": [{ "type": "query", "key": "direct" }],
      "destination": "/api/og/:id"
    },
    {
      "source": "/e/:id",
      "missing": [{ "type": "query", "key": "direct" }],
      "destination": "/api/og/:id"
    },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
