{
  "functions": {
    "api/og/[id].ts": {
      "includeFiles": "dist/index.html"
    }
  },
  "rewrites": [
    { "source": "/event/:id", "destination": "/api/og/:id" },
    { "source": "/e/:id",     "destination": "/api/og/:id" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
